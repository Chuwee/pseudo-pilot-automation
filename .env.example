# PseudoPilot Automation Environment Configuration

# Whisper Audio Transcription API
WHISPER_API_KEY=your_huggingface_token_here
WHISPER_MODEL=openai/whisper-large-v3-turbo

GPT_API_KEY=your_openai_api_key_here
GPT_MODEL=gpt-4o-mini

# Redis Configuration (for shared context database across processes)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_password_here  # Uncomment if Redis requires authentication
USE_REDIS=true  # Set to 'false' to use in-memory database instead
